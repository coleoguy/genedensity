permute.df <- read.csv("permute.csv")
fish.others <- permute.df[permute.df$response == "rsq" &
permute.df$dataset == "Actinopterygii" &
permute.df$variable == "prop.others", ]
run.cols <- grep("^run", colnames(permute.df), value = TRUE)
upper.vals <- as.numeric(fish.others[fish.others$stat == "upper", run.cols])
lower.vals <- as.numeric(fish.others[fish.others$stat == "lower", run.cols])
mid.vals   <- (upper.vals + lower.vals) / 2
mean(mid.vals, na.rm = TRUE)   # should be near 0
hist(mid.vals)
