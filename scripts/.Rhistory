strip_env <- function(f) { environment(f) <- baseenv(); f }
top.formula <- strip_env(formula(get.models(models, subset = 1)[[1]]))
set.formulas <- lapply(get.models(models, subset = TRUE),
function(m) strip_env(formula(m))
)
list(
out = out,
models = models,
dat = dat,
all.terms = all.terms,
