}
lines(density(df$r2.observed), col = "firebrick", lwd = 2)
lines(pp.x, pp.mean, col = "steelblue", lwd = 2, lty = 2)
# posterior distribution of slope
post <- as_draws_df(fit0, variable = "b_beta_Intercept")
