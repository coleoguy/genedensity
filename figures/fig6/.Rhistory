# read the response variables
rsq.df <- read.csv("../../results/rsq.csv")
rsq.df[[1]] <- tolower(gsub(" ", "_", rsq.df[[1]]))
species.col <- colnames(rsq.df)[1]
files <- list.files("../../results/divsums", pattern = "\\.divsum$", full.names = T)
clades <- c("Mammalia", "Actinopterygii", "Sauropsida")
responses  <- c("rsq", "gini.flip", "cv.flip")
resp.names <- c("rsq", "gini", "cv")
cutoffs <- seq(2, 20, by = 2)
sens.df <- data.frame()
for (k in cutoffs) {
v <- sapply(files, read.young.frac, cutoff = k, exclude = exclude.classes)
yf <- data.frame(
species = tolower(sub("\\.divsum$", "", basename(files))),
young.frac = as.numeric(v),
stringsAsFactors = F
)
yf <- yf[!is.na(yf$young.frac), ]
yf$species <- tolower(gsub(" ", "_", yf$species))
d <- merge(rsq.df, yf, by.x = species.col, by.y = "species")
d$gini.flip <- -d$gini
d$cv.flip <- -d$cv
for (ri in seq_along(responses)) {
resp <- responses[ri]
for (grp in c("All", clades)) {
sub <- if (grp == "All") d else d[d$clade == grp, ]
if (nrow(sub) < 5) next
y <- sub[[resp]]; x <- sub$young.frac
keep <- complete.cases(x, y)
y <- y[keep]; x <- x[keep]
m0 <- lm(y ~ 1)
m1 <- lm(y ~ x)
daic <- aicc(m0) - aicc(m1)
w1 <- exp(0.5 * daic) / (1 + exp(0.5 * daic))
beta <- coef(m1)[2]
sens.df <- rbind(sens.df, data.frame(
cutoff = k,
response = resp.names[ri],
group = grp,
n = length(y),
beta = beta,
delta.aicc = daic,
w1 = w1
))
}
}
}
group.pch <- c(All = 21, Mammalia = 22, Actinopterygii = 24, Sauropsida = 23)
ncol <- 10000
pal <- viridis(ncol, begin = 0, end = 0.8, option = "A")
w.min <- 0.5
w.max <- 1.0
temp <- c()
for (i in sens.df$w1) { # set color
out <- character(length(i))
unsup <- i < w.min
out[unsup] <- "white"
if (any(!unsup)) {
w.in <- i[!unsup]
idx <- round(((w.in - w.min) / (w.max - w.min)) * (ncol - 1)) + 1
out[!unsup] <- pal[pmax(1, pmin(ncol, idx))]
}
temp <- c(temp, out)
}
sens.df$point.col <- temp
par(mfrow = c(1, 1))
for (ri in seq_along(responses)) {
emf(paste0(ri, ".emf"), width = 8, height = 4)
resp.name <- resp.names[ri]
sub <- sens.df[sens.df$response == resp.name, ]
par(mar = c(5, 5, 3, 10) + 0.1)
y.range <- range(c(0, sub$beta), na.rm = TRUE)
y.pad <- max(diff(y.range), 0.05) * 0.15
y.range <- y.range + c(-y.pad, y.pad)
plot(NA, NA,
xlim = range(cutoffs), ylim = y.range,
xlab = "Kimura divergence cutoff (%)",
ylab = paste0("β for ", resp.name),
axes = FALSE, mgp = c(3, 0, 0))
title(main = paste0("Sensitivity: ", resp.name),
adj = 0, cex.main = 1.1)
axis(1, at = cutoffs, mgp = c(1, 0.8, 0))
axis(2, mgp = c(1, 0.8, 0))
box()
abline(h = 0, lty = 3, lwd = 0.8, col = "grey40")
abline(v = 9, lty = 3, lwd = 0.8, col = "grey40")
for (grp in c("All", clades)) {
ssub <- sub[sub$group == grp, ]
ssub <- ssub[order(ssub$cutoff), ]
if (nrow(ssub) == 0) next
lines(ssub$cutoff, ssub$beta, lwd = 1.2, col = "grey40")
points(ssub$cutoff, ssub$beta,
pch = group.pch[grp], bg = ssub$point.col,
col = "black", cex = 1.8, lwd = 0.7)
}
usr <- par("usr")
par(xpd = NA)
lx <- usr[2] + 0.04 * diff(usr[1:2])
legend(lx, usr[4],
legend = c("All", clades),
pch = group.pch[c("All", clades)],
col = "black",
pt.cex = 1.6,
title = "Group", title.adj = 0,
bty = "n", cex = 0.82, xjust = 0, yjust = 1)
margin.r.user <- diff(usr[1:2]) / par("pin")[1] * par("mai")[4]
bx1 <- usr[2] + 0.20 * margin.r.user
bx2 <- usr[2] + 0.92 * margin.r.user
by1 <- usr[3] + 0.04 * diff(usr[3:4])
by2 <- usr[3] + 0.08 * diff(usr[3:4])
bar_img <- array(t(col2rgb(pal) / 255), c(1, ncol, 3))
rasterImage(bar_img, bx1, by1, bx2, by2)
rect(bx1, by1, bx2, by2, border = "black", lwd = 0.8)
tick_at <- c(bx1, mean(c(bx1, bx2)), bx2)
tick_lab <- c("0.5", "0.75", "1.0")
axis(1, at = tick_at, labels = tick_lab,
pos = by1 - 0.015 * diff(usr[3:4]),
tck = -0.012, cex.axis = 0.65, mgp = c(1, -0.01, 1))
text(mean(c(bx1, bx2)), by2 + 0.03 * diff(usr[3:4]),
"w(M1)  (open: w < 0.5)", adj = c(0.5, 0), cex = 0.75)
par(xpd = FALSE)
dev.off()
}
