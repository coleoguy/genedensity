library(viridis)
library(devEMF) # svg doesn't work in powerpoint
combined.df <- read.csv("../../results/model-averaging.csv")
permute.df <- read.csv("../../results/permute.csv")
# keep rows where importance > 0.5 and CI doesn't include 0
combined.df <- combined.df[!is.na(combined.df$importance) &
combined.df$importance > 0.5 &
!is.na(combined.df$lower) &
!is.na(combined.df$upper) &
sign(combined.df$lower) == sign(combined.df$upper), ]
combined.df$obs.beta <- (combined.df$lower + combined.df$upper) / 2
run.cols <- grep("^run", colnames(permute.df), value = TRUE)
upper.df <- permute.df[permute.df$stat == "upper", ]
lower.df <- permute.df[permute.df$stat == "lower", ]
# match upper and lower rows
map <- function(x) paste(x$response, x$dataset, x$variable, sep = ",")
lower.df <- lower.df[match(map(upper.df), map(lower.df)), ]
# make 95% interval from midpoint
mid.mat <- (as.matrix(upper.df[, run.cols]) + as.matrix(lower.df[, run.cols])) / 2
null.q  <- t(apply(mid.mat, 1, quantile, probs = c(0.025, 0.975), na.rm = TRUE))
null.df <- data.frame(
response = upper.df$response,
dataset = upper.df$dataset,
variable = upper.df$variable,
null.lower = null.q[, 1],
null.upper = null.q[, 2]
)
combined.df <- merge(combined.df, null.df,
by.x = c("response", "clade", "model"),
by.y = c("response", "dataset", "variable"),
all.x = TRUE)
to.flip <- combined.df$response %in% c("gini", "cv")
combined.df$obs.beta.flip <- ifelse(to.flip,
-combined.df$obs.beta,
combined.df$obs.beta)
combined.df$null.lower.flip <- ifelse(to.flip,
-combined.df$null.upper,
combined.df$null.lower)
combined.df$null.upper.flip <- ifelse(to.flip,
-combined.df$null.lower,
combined.df$null.upper)
combined.df$adequate <- with(combined.df,
(obs.beta.flip < null.lower.flip | obs.beta.flip > null.upper.flip)
)
clades <- c("All", "Mammalia", "Actinopterygii", "Sauropsida")
combined.df$clade <- factor(combined.df$clade, levels = clades)
combined.df$response <- factor(combined.df$response, levels = c("rsq", "gini", "cv"))
# response offsets and shapes (match main.R)
response.offset <- c(rsq = 0.25, gini = 0, cv = -0.25)
response.pch    <- c(rsq = 21, gini = 22, cv = 24)
combined.df$pch <- response.pch[as.character(combined.df$response)]
par(mfrow = c(1, 1))
for (cl in clades) {
emf(paste0(cl, ".emf"), width = 7, height = 4)
dat <- combined.df[combined.df$clade == cl, ]
if (nrow(dat) == 0) {
plot.new(); title(main = paste0(cl, " — no significant predictors"))
dev.off()
next
}
par(mar = c(5, 8, 3, 10) + 0.1)
dat <- dat[order(dat$model, dat$response), ]
unique.models <- unique(dat$model)
y.base <- setNames(rev(seq_len(length(unique.models))), unique.models)
dat$y.base <- y.base[as.character(dat$model)]
dat$y <- dat$y.base + response.offset[as.character(dat$response)]
ylabs <- c()
for (i in unique.models) {
rep <- toupper(regmatches(i, regexpr("(?<=\\.)[a-zA-Z]+", i, perl = TRUE)))
if (length(rep) == 0) rep <- ""
if (rep == "OTHERS") rep <- "Others"
if (rep == "UNKNOWN") rep <- "Unknown"
if (rep == "TOTAL") rep <- "All repeats"
if (grepl(":", i)) { ylabs <- c(ylabs, paste(rep, "age x prop.")); next }
type <- if (sub("\\..*", "", i) == "prop") "proportion" else "age"
ylabs <- c(ylabs, paste(rep, type))
}
x.range <- range(c(dat$null.lower.flip, dat$null.upper.flip, dat$obs.beta.flip),
na.rm = TRUE) + c(-0.5, 0.5)
y.range <- range(dat$y) + c(-0.7, 0.7)
plot(dat$obs.beta.flip, dat$y, type = "n",
xlim = x.range, ylim = y.range,
xlab = "Sign-aligned β", ylab = NA, axes = FALSE,
mgp = c(2.5, 0, 0))
title(main = cl,
line = 0.8, adj = 0, cex.main = 1.05)
abline(v = 0, lty = 5, lwd = 1, col = "black")
for (p in seq_len(length(unique.models) - 1)) {
abline(h = p + 0.5, lty = 3, lwd = 0.5, col = "grey85")
}
points(dat$obs.beta.flip,
dat$y,
pch = dat$pch,
cex = 1.8,
bg = ifelse(dat$adequate, "#92c5de", "grey40"),
col = "black",
lwd = 0.6)
segments(dat$null.lower.flip, dat$y, dat$null.upper.flip, dat$y,
lwd = 2, col = "#ca0020")
segments(dat$null.lower.flip, dat$y - 0.15, dat$null.lower.flip, dat$y + 0.15,
lwd = 2, col = "#ca0020")
segments(dat$null.upper.flip, dat$y - 0.15, dat$null.upper.flip, dat$y + 0.15,
lwd = 2, col = "#ca0020")
axis(1, at = pretty(x.range), mgp = c(1, 0.8, 0))
axis(1, at = seq(-10, 10, by = 0.5), labels = FALSE, tcl = -0.2)
axis(1, at = seq(-10, 10, by = 1),   labels = FALSE, tcl = -0.5)
axis(2, at = y.base, labels = ylabs, las = 2, cex.axis = 0.9)
box()
usr <- par("usr"); par(xpd = NA)
lx <- usr[2] + 0.04 * diff(usr[1:2])
legend(lx, usr[4],
legend = c("R²", "Gini", "CV"),
col = "black",
pch = response.pch[c("rsq", "gini", "cv")],
lwd = 1.4, pt.cex = 1.6,
title = "Response metric", title.adj = 0,
bty = "n", cex = 0.82, xjust = 0, yjust = 1)
legend(lx, usr[4] - 0.35 * diff(usr[3:4]),
legend = c("Outside null", "Inside null"),
pch = 21,
pt.bg = c("#92c5de", "grey40"),
col = "black",
pt.lwd = 0.6,
pt.cex = 1.6,
title = "Adequacy", title.adj = 0,
bty = "n", cex = 0.82, xjust = 0, yjust = 1)
par(xpd = FALSE)
dev.off()
}
