print(paste0("=== Response variable: ", response, " ==="))
# ---- 1. Main analysis ----
print("  Running main analysis...")
main.results <- future_lapply(clades, function(clade) {
run_full_analysis(rsq, repeats, clade, response = response)
}, future.seed = TRUE)
names(main.results) <- clades
this.main <- do.call(rbind, lapply(main.results, function(x) x$out))
this.main <- this.main[this.main$importance > 0.5, ]
combined.df <- rbind(combined.df, this.main)
# ---- 2. All-repeats analysis ----
# Reviewer 2 minor comment 3: include a combined-repeats predictor.
# Run as a separate analysis to avoid perfect collinearity with per-class predictors.
print("  Running all-repeats analysis...")
allrepeats.results <- future_lapply(clades, function(clade) {
run_full_analysis(rsq, repeats, clade, response = response,
variables    = c("prop.total", "age.total"),
custom.terms = c("prop.total", "age.total", "prop.total:age.total"))
}, future.seed = TRUE)
names(allrepeats.results) <- clades
this.ar <- do.call(rbind, lapply(allrepeats.results, function(x) x$out))
this.ar <- this.ar[this.ar$importance > 0.5, ]
allrepeats.df <- rbind(allrepeats.df, this.ar)
# ---- 3. LOSO validation ----
# Refit only the top-AICc model after dropping each species in turn.
print("  Running LOSO validation...")
for (clade in clades) {
dat         <- main.results[[clade]]$dat
top.formula <- main.results[[clade]]$top.formula
with_progress({
p <- progressor(steps = nrow(dat))
loso.list <- future_lapply(seq_len(nrow(dat)), function(i) {
fit   <- glm(top.formula, data = dat[-i, ])
coefs <- coef(fit)
p(sprintf("[%s] dropped %s", clade, dat$species[i]))
data.frame(
response        = response,
clade           = clade,
dropped.species = dat$species[i],
predictor       = names(coefs),
coef            = coefs,
row.names       = NULL
)
}, future.seed = TRUE)
})
loso.df <- rbind(loso.df, do.call(rbind, loso.list))
}
# ---- 4. Random subsample validation ----
# Drop a random 20% of species; refit the original 95% confidence set.
print("  Running random subsample validation...")
n.iter <- 1000
for (clade in clades) {
dat          <- main.results[[clade]]$dat
set.formulas <- main.results[[clade]]$set.formulas
all.terms    <- main.results[[clade]]$all.terms
sub.list <- future_lapply(seq_len(n.iter), function(b) {
idx     <- sample(seq_len(nrow(dat)), size = round(0.8 * nrow(dat)))
sub.dat <- dat[idx, ]
res <- tryCatch({
fits        <- lapply(set.formulas, function(f) glm(f, data = sub.dat))
names(fits) <- paste0("M", seq_along(fits))
models.sub  <- model.sel(fits)
ci.table    <- extract_ci_table(models.sub, all.terms)
ci.table$response  <- response
ci.table$clade     <- clade
ci.table$iter      <- b
ci.table$predictor <- rownames(ci.table)
rownames(ci.table) <- NULL
ci.table
}, error = function(e) NULL)
return(res)
}, future.seed = TRUE)
subsample.df <- rbind(subsample.df, do.call(rbind, sub.list))
}
# ---- 5. High-influence exclusion ----
# Drop top 10% Cook's D species, re-dredge from scratch.
print("  Running high-influence exclusion...")
highinf.results <- future_lapply(clades, function(clade) {
dat         <- main.results[[clade]]$dat
top.formula <- main.results[[clade]]$top.formula
top.model <- glm(top.formula, data = dat)
cd        <- cooks.distance(top.model)
n.drop           <- ceiling(0.10 * nrow(dat))
drop.idx         <- order(cd, decreasing = TRUE)[1:n.drop]
dropped.species  <- dat$species[drop.idx]
rsq.filtered <- rsq[!rsq$species %in% dropped.species, ]
result       <- run_full_analysis(rsq.filtered, repeats, clade, response = response)
if (nrow(result$out) > 0) {
result$out$num.dropped     <- n.drop
result$out$dropped.species <- paste(dropped.species, collapse = ";")
}
return(result$out)
}, future.seed = TRUE)
this.hi <- do.call(rbind, highinf.results)
this.hi <- this.hi[this.hi$importance > 0.5, ]
highinf.df <- rbind(highinf.df, this.hi)
}
# Zhaobo Hu
# zhaobohu2002@gmail.com
# Finds significant models and predictors of gene density homogeneity using
# IT-based model averaging. Runs across three response variables to test
# robustness to dispersion-metric choice (Reviewer 1 validation A):
#   - rsq:  R-squared from contig-size vs gene-count linear fit
#   - gini: Gini coefficient of gene density across contigs
#   - cv:   coefficient of variation of gene density across contigs
#
# For each response variable, runs five analyses (parallelized where applicable):
#   (1) main analysis with parallelization across clades
#   (2) parallel run with combined "all-repeats" predictors (prop.total, age.total)
#   (3) leave-one-species-out (LOSO): refit the top model after dropping each species
#   (4) random 80% subsample (1000x): refit the original 95% confidence set
#   (5) high-influence exclusion: drop top 10% Cook's D species, then re-dredge
library(MuMIn)
library(phytools)
library(caper)
library(future.apply)
source("functions.R")
library(progressr)
handlers(global = TRUE)
handlers("txtprogressbar")
options(na.action = "na.fail")
options(future.globals.maxSize = 4 * 1024^3)
# ---------------- Read data ----------------
rsq     <- read.csv("../results/rsq.csv")
repeats <- read.csv("../results/repeat-results.csv")
tree    <- read.tree("../data/formatted-tree.nwk")
clades    <- c("All", "Mammalia", "Actinopterygii", "Sauropsida")
responses <- c("rsq", "gini", "cv")
# ---------------- Helper functions ----------------
# Prepare data for one clade and one response variable
prep_data <- function(rsq, repeats, clade, response = "rsq", variables = NULL) {
dat <- merge(rsq, repeats, by = "species", all = TRUE)
if (clade != "All") {
dat <- dat[dat$clade %in% clade, ]
}
if (is.null(variables)) {
variables <- colnames(dat)[grep("^(prop|age)\\.", colnames(dat))]
# exclude the combined predictors from the per-class analysis
variables <- setdiff(variables, c("prop.total", "age.total"))
}
dat <- na.omit(dat[, c("species", "clade", response, variables)])
for (j in variables) {
if (diff(range(dat[[j]])) > 0) {
dat[[j]] <- (dat[[j]] - min(dat[[j]])) / diff(range(dat[[j]]))
}
}
list(dat = dat, variables = variables)
}
# Fit all valid models from a predictor set; return model.sel table trimmed to 95% weight
fit_all_models <- function(dat, all.terms, response = "rsq") {
n <- nrow(dat)
max.vars <- min(n - 2, length(all.terms))
fml <- as.formula(paste(response, "~", paste(all.terms, collapse = " + ")))
global.model <- glm(fml, data = dat, na.action = "na.fail")   # explicit
models <- dredge(global.model, m.lim = c(0, max.vars))
models <- models[order(models$AICc), ]
keep <- (cumsum(models$weight) - models$weight) < 0.95
if (sum(keep) < 2 && nrow(models) >= 2) keep[1:2] <- TRUE
models <- models[keep, ]
gc()
return(models)
}
# Extract importance/CI table from a model.sel object
extract_ci_table <- function(models, all.terms) {
ci.table <- data.frame(matrix(NA, nrow = length(all.terms), ncol = 3))
colnames(ci.table) <- c("importance", "lower", "upper")
rownames(ci.table) <- all.terms
ci.table[names(sw(models)), 1] <- sw(models)
ci <- confint(model.avg(models))
ci.found <- intersect(row.names(ci), all.terms)
ci.table[ci.found, 2:3] <- ci[ci.found, ]
return(ci.table)
}
# Format CI table into a tidy data frame, optionally filtered to significant predictors
build_ci_df <- function(ci.table, clade, num.models, response = "rsq", sig.only = TRUE) {
if (sig.only) {
idx <- which(sign(ci.table[, 2]) == sign(ci.table[, 3]))
ci.table <- ci.table[idx, , drop = FALSE]
}
if (nrow(ci.table) == 0) return(data.frame())
data.frame(
response   = response,
clade      = clade,
model      = rownames(ci.table),
num.models = num.models,
estimate   = sapply(seq_len(nrow(ci.table)), function(x) mean(unlist(ci.table[x, 2:3]))),
importance = ci.table$importance,
lower      = ci.table$lower,
upper      = ci.table$upper
)
}
# Run a full analysis (build predictors, dredge, average) for one clade and response
run_full_analysis <- function(rsq, repeats, clade, response = "rsq",
variables = NULL, custom.terms = NULL) {
prepped <- prep_data(rsq, repeats, clade, response = response, variables = variables)
dat  <- prepped$dat
vars <- prepped$variables
if (is.null(custom.terms)) {
repeat.types <- unique(sub("^[^.]*\\.", "", vars))
interactions <- paste0("age.", repeat.types, ":prop.", repeat.types)
all.terms <- c(vars, interactions)
} else {
all.terms <- custom.terms
}
models   <- fit_all_models(dat, all.terms, response = response)
ci.table <- extract_ci_table(models, all.terms)
out      <- build_ci_df(ci.table, clade, nrow(models), response = response, sig.only = TRUE)
strip_env <- function(f) { environment(f) <- baseenv(); f }
top.formula  <- strip_env(formula(get.models(models, subset = 1)[[1]]))
set.formulas <- lapply(get.models(models, subset = TRUE), function(m) strip_env(formula(m)))
list(
out          = out,
models       = models,
dat          = dat,
all.terms    = all.terms,
response     = response,
top.formula  = top.formula,
set.formulas = set.formulas
)
}
# ---------------- Setup parallel ----------------
plan(multisession, workers = 8)
# ---------------- Initialize output accumulators ----------------
combined.df   <- data.frame()
allrepeats.df <- data.frame()
loso.df       <- data.frame()
subsample.df  <- data.frame()
highinf.df    <- data.frame()
# ---------------- Outer loop: one pass per response variable ----------------
for (response in responses) {
print(paste0("=== Response variable: ", response, " ==="))
# ---- 1. Main analysis ----
print("  Running main analysis...")
main.results <- future_lapply(clades, function(clade) {
run_full_analysis(rsq, repeats, clade, response = response)
}, future.seed = TRUE)
names(main.results) <- clades
this.main <- do.call(rbind, lapply(main.results, function(x) x$out))
this.main <- this.main[this.main$importance > 0.5, ]
combined.df <- rbind(combined.df, this.main)
# ---- 2. All-repeats analysis ----
# Reviewer 2 minor comment 3: include a combined-repeats predictor.
# Run as a separate analysis to avoid perfect collinearity with per-class predictors.
print("  Running all-repeats analysis...")
allrepeats.results <- future_lapply(clades, function(clade) {
run_full_analysis(rsq, repeats, clade, response = response,
variables    = c("prop.total", "age.total"),
custom.terms = c("prop.total", "age.total", "prop.total:age.total"))
}, future.seed = TRUE)
names(allrepeats.results) <- clades
this.ar <- do.call(rbind, lapply(allrepeats.results, function(x) x$out))
this.ar <- this.ar[this.ar$importance > 0.5, ]
allrepeats.df <- rbind(allrepeats.df, this.ar)
# ---- 3. LOSO validation ----
# Refit only the top-AICc model after dropping each species in turn.
print("  Running LOSO validation...")
for (clade in clades) {
dat         <- main.results[[clade]]$dat
top.formula <- main.results[[clade]]$top.formula
with_progress({
p <- progressor(steps = nrow(dat))
loso.list <- future_lapply(seq_len(nrow(dat)), function(i) {
fit   <- glm(top.formula, data = dat[-i, ])
coefs <- coef(fit)
p(sprintf("[%s] dropped %s", clade, dat$species[i]))
data.frame(
response        = response,
clade           = clade,
dropped.species = dat$species[i],
predictor       = names(coefs),
coef            = coefs,
row.names       = NULL
)
}, future.seed = TRUE)
})
loso.df <- rbind(loso.df, do.call(rbind, loso.list))
}
# ---- 4. Random subsample validation ----
# Drop a random 20% of species; refit the original 95% confidence set.
print("  Running random subsample validation...")
n.iter <- 1000
for (clade in clades) {
dat          <- main.results[[clade]]$dat
set.formulas <- main.results[[clade]]$set.formulas
all.terms    <- main.results[[clade]]$all.terms
sub.list <- future_lapply(seq_len(n.iter), function(b) {
idx     <- sample(seq_len(nrow(dat)), size = round(0.8 * nrow(dat)))
sub.dat <- dat[idx, ]
res <- tryCatch({
fits        <- lapply(set.formulas, function(f) glm(f, data = sub.dat))
names(fits) <- paste0("M", seq_along(fits))
models.sub  <- model.sel(fits)
ci.table    <- extract_ci_table(models.sub, all.terms)
ci.table$response  <- response
ci.table$clade     <- clade
ci.table$iter      <- b
ci.table$predictor <- rownames(ci.table)
rownames(ci.table) <- NULL
ci.table
}, error = function(e) NULL)
return(res)
}, future.seed = TRUE)
subsample.df <- rbind(subsample.df, do.call(rbind, sub.list))
}
# ---- 5. High-influence exclusion ----
# Drop top 10% Cook's D species, re-dredge from scratch.
print("  Running high-influence exclusion...")
highinf.results <- future_lapply(clades, function(clade) {
dat         <- main.results[[clade]]$dat
top.formula <- main.results[[clade]]$top.formula
top.model <- glm(top.formula, data = dat)
cd        <- cooks.distance(top.model)
n.drop           <- ceiling(0.10 * nrow(dat))
drop.idx         <- order(cd, decreasing = TRUE)[1:n.drop]
dropped.species  <- dat$species[drop.idx]
rsq.filtered <- rsq[!rsq$species %in% dropped.species, ]
result       <- run_full_analysis(rsq.filtered, repeats, clade, response = response)
if (nrow(result$out) > 0) {
result$out$num.dropped     <- n.drop
result$out$dropped.species <- paste(dropped.species, collapse = ";")
}
return(result$out)
}, future.seed = TRUE)
this.hi <- do.call(rbind, highinf.results)
this.hi <- this.hi[this.hi$importance > 0.5, ]
highinf.df <- rbind(highinf.df, this.hi)
}
# ---------------- Write outputs ----------------
write.csv(combined.df,   "../results/model-averaging.csv",                 row.names = FALSE)
write.csv(allrepeats.df, "../results/model-averaging-allrepeats.csv",      row.names = FALSE)
write.csv(loso.df,       "../results/loso.csv",                            row.names = FALSE)
write.csv(subsample.df,  "../results/subsample.csv",                       row.names = FALSE)
write.csv(highinf.df,    "../results/model-averaging-highinfluence.csv",   row.names = FALSE)
print("All analyses complete.")
warnings()
View(loso.df)
View(dat)
View(loso.df)
library(ggplot2)
library(dplyr)
dat <- read.csv("../results/model-averaging.csv")
# Flip gini and cv signs so all three responses point the same biological direction
dat <- dat %>%
mutate(
estimate.flip = ifelse(response %in% c("gini", "cv"), -estimate, estimate),
lower.flip    = ifelse(response %in% c("gini", "cv"), -upper,    lower),
upper.flip    = ifelse(response %in% c("gini", "cv"), -lower,    upper)
)
# Order clades and responses for plotting
dat$clade    <- factor(dat$clade,    levels = c("All", "Mammalia", "Actinopterygii", "Sauropsida"))
dat$response <- factor(dat$response, levels = c("rsq", "gini", "cv"),
labels = c("R²", "Gini", "CV"))
# Order predictors: proportions first, then ages, then interactions
predictor.order <- function(p) {
type   <- ifelse(grepl(":", p), 3,                # interactions last
ifelse(grepl("^prop\\.", p), 1, 2))     # prop first, age second
paste(type, p)
}
dat$predictor.sorted <- factor(dat$model, levels = unique(dat$model[order(predictor.order(dat$model))]))
# Forest plot
p <- ggplot(dat, aes(x = estimate.flip, y = predictor.sorted, color = response)) +
geom_vline(xintercept = 0, linetype = "dashed", color = "grey50") +
geom_pointrange(aes(xmin = lower.flip, xmax = upper.flip),
position = position_dodge(width = 0.6),
size = 0.4) +
facet_wrap(~ clade, scales = "free_y", ncol = 2) +
scale_color_manual(values = c("R²" = "#1f78b4", "Gini" = "#e31a1c", "CV" = "#33a02c"),
name = "Response metric") +
labs(x = "Sign-aligned coefficient estimate (positive = more homogeneous)",
y = NULL,
title = "Significant model-averaged predictors of gene density homogeneity",
caption = "Coefficients for Gini and CV have been sign-flipped to align with R² (positive = more homogeneous).") +
theme_bw(base_size = 11) +
theme(legend.position = "top",
panel.grid.major.y = element_line(color = "grey90"),
plot.caption = element_text(hjust = 0, size = 8, color = "grey30"))
ggsave("../figures/forest-main.pdf", p, width = 9, height = 7)
ggsave("../figures/forest-main.png", p, width = 9, height = 7, dpi = 300)
print(p)
